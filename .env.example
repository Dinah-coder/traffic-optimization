# Local backend API URL
VITE_API_URL=http://localhost:8000

# Real map tile provider. Use your preferred tile server or Mapbox style.
# For Mapbox use: https://api.mapbox.com/styles/v1/{username}/{style_id}/tiles/256/{z}/{x}/{y}@2x?access_token=YOUR_MAPBOX_TOKEN
VITE_MAP_TILES_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_ATTRIBUTION=&copy; OpenStreetMap contributors

# Default map center around Kigali
VITE_MAP_CENTER_LAT=-1.9440
VITE_MAP_CENTER_LNG=30.08
VITE_MAP_ZOOM=12
